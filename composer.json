{
  "name": "devlin/myinfo-singpass",
  "description": "PHP wrapper SDK for MyInfo integrations.",
  "type": "library",
  "license": "proprietary",
  "require": {
    "php": ">=7.4",
    "guzzlehttp/guzzle": "^7.0",
    "web-token/jwt-framework": "^2.2",
    "psr/log": "^1.1",
    "nesbot/carbon": "^2.0"
  },
  "require-dev": {
    "illuminate/support": "^8.0",
    "illuminate/contracts": "^8.0"
  },
  "autoload": {
    "psr-4": {
      "MyInfo\\": "src/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "MyInfo\\Laravel\\MyInfoServiceProvider"
      ],
      "aliases": {
        "MyInfo": "MyInfo\\Laravel\\Facades\\MyInfo"
      }
    }
  }
}
